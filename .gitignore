# Secrets y configuración local (nunca subir .env reales)
backend/.env
frontend/.env

# Bases de datos locales
*.db
*.sqlite3

# Python
backend/.venv/
__pycache__/
*.pyc

# Node / Expo
frontend/node_modules/
frontend/.expo/

# Admin panel (Next.js)
admin-web/node_modules/
admin-web/.next/
admin-web/.env.local

# IDE y sistema
.vscode/*.log
Thumbs.db
.DS_Store
.aider*

# Claude Code: permisos locales por máquina (el resto de .claude/ sí se versiona)
.claude/settings.local.json
.mcp.json

# Artefactos generados por graphify (knowledge graph, ~1.4 MB).
# Se regenera con `graphify update .` (sin coste de API).
graphify-out/

# Cachés de tooling
.mypy_cache/
.ruff_cache/
.pytest_cache/

#!/usr/bin/env sh
# Escudo de calidad en cada commit (monorepo: frontend + backend conviven en un solo hook).
# Husky es el dueño del git hook (core.hooksPath -> .husky/_) y orquesta los dos sistemas.
# El cwd al ejecutarse es la RAÍZ del repo.

# --- 1) Frontend: TypeScript + ESLint + Prettier sobre los ficheros staged (lint-staged) ---
( cd frontend && npx lint-staged ) || exit 1

# --- 2) Backend: Ruff + Mypy vía el framework pre-commit (reusa su config y su caché) ---
# Orden de búsqueda: PATH primero (uv tool install / pip install --user), luego
# el módulo dentro de los venvs del proyecto como respaldo.
# NOTA: no ejecutar «pre-commit install» — sobreescribiría core.hooksPath de Husky.
if command -v pre-commit >/dev/null 2>&1; then
  pre-commit run --config .pre-commit-config.yaml || exit 1
elif [ -x "backend/.venv/Scripts/python.exe" ] && "backend/.venv/Scripts/python.exe" -c "import pre_commit" 2>/dev/null; then
  "backend/.venv/Scripts/python.exe" -m pre_commit run --config .pre-commit-config.yaml || exit 1
elif [ -x "backend/.venv/bin/python" ] && "backend/.venv/bin/python" -c "import pre_commit" 2>/dev/null; then
  "backend/.venv/bin/python" -m pre_commit run --config .pre-commit-config.yaml || exit 1
else
  echo "husky: el escudo del backend (pre-commit) no está disponible." >&2
  echo "       Instálalo con:  uv tool install pre-commit" >&2
  exit 1
fi

#!/usr/bin/env sh
# Escudo de calidad en cada commit (monorepo: frontend + backend conviven en un solo hook).
# Husky es el dueño del git hook (core.hooksPath -> .husky/_) y orquesta los dos sistemas.
# El cwd al ejecutarse es la RAÍZ del repo.

# --- 1) Frontend: TypeScript + ESLint + Prettier sobre los ficheros staged (lint-staged) ---
( cd frontend && npx lint-staged ) || exit 1

# --- 2) Backend: Ruff + Mypy vía el framework pre-commit (reusa su config y su caché) ---
# pre-commit no está en el PATH: vive en el .venv de la raíz. Probamos en orden y, si no,
# avisamos cómo activarlo en vez de saltarnos el escudo en silencio.
if [ -x ".venv/Scripts/python.exe" ]; then
  ".venv/Scripts/python.exe" -m pre_commit run --config .pre-commit-config.yaml || exit 1
elif [ -x ".venv/bin/python" ]; then
  ".venv/bin/python" -m pre_commit run --config .pre-commit-config.yaml || exit 1
elif command -v pre-commit >/dev/null 2>&1; then
  pre-commit run --config .pre-commit-config.yaml || exit 1
else
  echo "husky: el escudo del backend (pre-commit) no está disponible." >&2
  echo "       Actívalo con:  uv run pre-commit install" >&2
  exit 1
fi

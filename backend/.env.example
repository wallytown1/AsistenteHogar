# Plantilla de configuración del backend. Copia este archivo a `.env` y rellena los valores.
# NUNCA subas el archivo .env real a un repositorio.

# Cadena de conexión asíncrona. Desarrollo local con SQLite:
#   sqlite+aiosqlite:///./asistente_hogar.db
# Producción con PostgreSQL:
#   postgresql+asyncpg://usuario:contrasena@host:5432/asistente_hogar
DATABASE_URL=sqlite+aiosqlite:///./asistente_hogar.db

# Clave secreta para firmar tokens JWT. Genera una aleatoria larga, por ejemplo:
#   python -c "import secrets; print(secrets.token_hex(48))"
JWT_SECRET_KEY=

# Entorno: development | production
ENVIRONMENT=development

# Orígenes CORS permitidos, separados por coma (solo necesario para clientes web)
ALLOWED_ORIGINS=

# Clave de Google Gemini (https://aistudio.google.com). Opcional: sin ella el
# briefing se genera en modo de contingencia y no hay sugerencias de recetas.
GEMINI_API_KEY=

# Modelo de Gemini a usar (por defecto gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Minutos de validez del token de acceso (por defecto 43200 = 30 días)
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Redis. Opcional: sin ella la caché y el rate-limit operan en memoria (solo
# válido con un único worker). En producción con múltiples workers, apuntar a
# un Redis compartido. Desarrollo local con Docker:
#   redis://localhost:6379/0
REDIS_URL=

# RevenueCat (freemium). Clave SECRETA del servidor (panel RevenueCat > API keys
# > Secret key), NO la SDK key pública del cliente. Sin ella, el gate premium se
# desactiva y los endpoints de IA quedan abiertos (modo desarrollo/test). En
# producción debe estar definida para aplicar el freemium en el servidor.
REVENUECAT_SECRET_KEY=
# Identificador del entitlement premium configurado en RevenueCat.
REVENUECAT_ENTITLEMENT=premium

# Panel de administración. Clave separada de JWT_SECRET_KEY: los tokens admin y
# los tokens familiares no son intercambiables. Sin ADMIN_JWT_SECRET_KEY los
# endpoints /admin/* responden 503.
#   python -c "import secrets; print(secrets.token_hex(48))"
ADMIN_JWT_SECRET_KEY=
# Minutos de validez del token de admin (por defecto 480 = 8 horas)
ADMIN_JWT_EXPIRE_MINUTES=480
# Token de un solo uso para crear el primer admin. Genera uno y úsalo una sola
# vez (POST /api/v1/admin/auth/bootstrap). Desactivado si está vacío (501).
ADMIN_BOOTSTRAP_TOKEN=

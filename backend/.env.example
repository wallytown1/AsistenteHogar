# Plantilla de configuración del backend. Copia este archivo a `.env` y rellena los valores.
# NUNCA subas el archivo .env real a un repositorio.

# Cadena de conexión asíncrona. Desarrollo local con SQLite:
#   sqlite+aiosqlite:///./asistente_hogar.db
# Producción con PostgreSQL:
#   postgresql+asyncpg://usuario:contrasena@host:5432/asistente_hogar
DATABASE_URL=sqlite+aiosqlite:///./asistente_hogar.db

# Clave secreta para firmar tokens JWT. Genera una aleatoria larga, por ejemplo:
#   python -c "import secrets; print(secrets.token_hex(48))"
JWT_SECRET_KEY=

# Entorno: development | production
ENVIRONMENT=development

# Orígenes CORS permitidos, separados por coma (solo necesario para clientes web)
ALLOWED_ORIGINS=

# Clave de Google Gemini (https://aistudio.google.com). Opcional: sin ella el
# briefing se genera en modo de contingencia con los datos de la base de datos.
GEMINI_API_KEY=

# Minutos de validez del token de acceso (por defecto 43200 = 30 días)
ACCESS_TOKEN_EXPIRE_MINUTES=43200

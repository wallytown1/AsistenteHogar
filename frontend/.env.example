# Plantilla de variables de entorno del frontend (Expo).
# Copia a `.env.development` y `.env.production` y rellena los valores.
# Las variables EXPO_PUBLIC_* se EMBEBEN en el bundle del cliente: no pongas
# aquí secretos de servidor (claves privadas, tokens de admin, etc.).

# URL base de la API del backend.
#   Local:      http://TU_IP_LAN:8000/api/v1
#   Producción: https://<tu-servicio>.up.railway.app/api/v1
EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1

# SDK key PÚBLICA de RevenueCat (panel > API keys > App-specific public key).
#   - Empieza por appl_ (iOS) o goog_ (Android), NO por test_.
#   - Las claves test_ son de sandbox: un build de producción con una clave
#     test_ NO procesará compras reales.
EXPO_PUBLIC_RC_KEY=

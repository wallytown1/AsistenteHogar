{
  "name": "asistente-hogar-frontend",
  "version": "1.0.0",
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "ts:check": "tsc",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "node -e \"process.env.CI || require('child_process').execSync('husky', {cwd: require('path').resolve('..'), stdio: 'inherit', shell: true})\""
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/bottom-tabs": "^7.3.0",
    "@react-navigation/native": "^7.3.0",
    "@react-navigation/native-stack": "^7.17.5",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.0",
    "expo-audio": "~1.1.1",
    "expo-file-system": "~19.0.23",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-notifications": "~0.32.17",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-purchases": "^10.3.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~19.1.10",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^56.0.4",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "^3.8.4",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "eslint-import-resolver-typescript": "3.6.3"
  },
  "private": true
}
